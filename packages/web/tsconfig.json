{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "..",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@lib/*": ["../core/src/lib/*"],
      "@kernel/*": ["../core/src/kernel/*"],
      "@components/*": ["../core/src/components/*"],
      "@themes/*": ["../themes/*"],
      "@vc/theme": ["../theme/src/index.ts"],
      "@vc/theme/*": ["../theme/src/*"],
      "@vc/core": ["../core/src/index.ts"],
      "@vc/core/kernel/pages/*": ["./src/pages/*"],
      "@vc/core/*": ["../core/src/*"],
      "@vc/theme-nativa": ["../themes/nativa/src/index.ts"],
      "@vc/theme-nativa/*": ["../themes/nativa/src/*"]
    }
  },
  "include": ["src/**/*", "../core/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "../core/src/**/*.test.ts"
  ]
}
