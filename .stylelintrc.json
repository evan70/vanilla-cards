{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": [
      "^([a-z][a-z0-9]*)(__[a-z][a-z0-9]*)?(--[a-z][a-z0-9]*)?$",
      {
        "message": "Class names must follow BEM format: block__element--modifier"
      }
    ],
    "selector-max-id": 0,
    "selector-no-qualifying-type": true,
    "max-nesting-depth": 1
  }
}
