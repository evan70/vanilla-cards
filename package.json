{
  "name": "vc",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "init": "turbo run init",
    "db:push": "turbo run db:push --filter=@vc/shared",
    "db:migrate": "turbo run db:migrate --filter=@vc/shared",
    "db:studio": "turbo run db:studio --filter=@vc/shared",
    "lint": "turbo run lint",
    "lint:css": "stylelint \"packages/**/*.css\"",
    "view": "turbo run build && turbo run preview",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "dompurify": "^3.4.1",
    "marked": "^18.0.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils": "npm:tsx@^4.21.0",
      "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
      "prebuild-install": "github:prebuild/prebuild-install#v7.1.3"
    }
  },
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22"
  }
}
